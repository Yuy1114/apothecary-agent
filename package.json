{
  "name": "apothecary-agent",
  "version": "1.1.0",
  "main": "dist/desktop/main.js",
  "description": "Mastra-native agent for local Markdown knowledge bases.",
  "type": "module",
  "scripts": {
    "dev": "mastra dev",
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "vitest",
    "ci": "pnpm run check && pnpm run build && pnpm vitest run",
    "desktop:dev": "pnpm run build && electron .",
    "desktop:pack": "pnpm run build && electron-builder --dir",
    "desktop:dist": "pnpm run build && electron-builder"
  },
  "keywords": [
    "agent",
    "markdown",
    "pkm",
    "vault"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/openai": "^4.0.4",
    "@ai-sdk/openai-compatible": "^3.0.2",
    "@libsql/client": "^0.17.4",
    "@mastra/core": "^1.47.0",
    "@mastra/duckdb": "^1.5.0",
    "@mastra/evals": "^1.5.1",
    "@mastra/libsql": "^1.14.2",
    "@mastra/loggers": "^1.2.0",
    "@mastra/memory": "^1.21.2",
    "@mastra/observability": "^1.15.2",
    "@mastra/rag": "^2.3.0",
    "ai": "^7.0.8",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "mastra": "^1.16.0",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "vitest": "^4.0.15"
  },
  "build": {
    "appId": "com.yuy.apothecary-agent",
    "productName": "Apothecary",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/desktop/renderer",
        "to": "renderer"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    }
  }
}
