    "commander": "^14.0.2",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "mastra": "^1.16.0",
    "openai": "^6.45.0",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
